# Normalize line endings: store text as LF in the repo
* text=auto eol=lf

*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.env.example text eol=lf

# Binary assets (never normalized)
*.mp3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
