# oecu-bot updater host configuration
# This file is installed to /etc/oecu-bot-updater.env by deploy/install-updater.sh.

COMPOSE_DIR=@COMPOSE_DIR@
DATA_DIR=@DATA_DIR@
COMPOSE_SERVICE=oecu-bot
CONTAINER_NAME=oecu-bot

OECU_BOT_IMAGE=ghcr.io/hiryuto-oecu/oecu-discord-bot
PROD_IMAGE_TAG=latest
DEV_IMAGE_TAG=dev

MODE_STATE_FILE=@DATA_DIR@/mode_state.json
UPDATE_TRIGGER_FILE=@DATA_DIR@/update_trigger.json
UPDATE_STATUS_FILE=@DATA_DIR@/update_status.json

HEALTHCHECK_TIMEOUT_SECONDS=180
HEALTHCHECK_POLL_SECONDS=5
ROLLBACK_TAG_PREFIX=rollback
