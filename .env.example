# Discord
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
BOT_OWNER_ID=
DISCORD_GUILD_IDS=1355832680557580511

# Runtime
RESTART_EXIT_CODE=42
DATA_DIR=data
SOUND_DIR=sounds

# Docker updater / healthcheck
OECU_BOT_IMAGE_REF=ghcr.io/hiryuto-oecu/oecu-discord-bot:latest
OECU_BOT_IMAGE=ghcr.io/hiryuto-oecu/oecu-discord-bot
OECU_BOT_IMAGE_TAG=latest
MODE_STATE_FILE=data/mode_state.json
UPDATE_TRIGGER_FILE=data/update_trigger.json
UPDATE_STATUS_FILE=data/update_status.json
UPDATE_NOTIFY_STATE_FILE=data/update_notify_state.json
UPDATE_NOTIFY_CHANNEL_FILE=data/update_notify_channel.json
UPDATE_NOTIFY_CHANNEL_ID=
UPDATE_STATUS_CHECK_INTERVAL_SECONDS=60
HEARTBEAT_FILE=data/heartbeat.json
HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_MAX_AGE_SECONDS=120

# File change notification
WATCH_FILE_PATH=data/change.json
WATCH_CHANNEL_ID=1361230916088758521
WATCH_ROLE_ID=1361711315260805331

# /assign_role
ASSIGNABLE_ROLE_IDS=1361711315260805331

# Email verification
VERIFY_FILE=data/verify.json
CODE_EXPIRATION_MINUTES=10
SENDER_EMAIL=大学支援Bot <university.bot.verify@gmail.com>
# Docker 内の localhost はコンテナ自身です。
# ホスト側 Postfix を使う場合は Docker Desktop なら host.docker.internal を検討してください。
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
VERIFIED_ROLE_ID=1371375954663968808
EVEN_VERIFIED_ROLE_ID=1365240658104680448
ODD_VERIFIED_ROLE_ID=1365241396117770280

# Reaction delete / timeout
REACTION_WHITELIST_CHANNEL_IDS=1362265150005973002,1369989530471497728
REACTION_TARGET_EMOJI=⚠️
REACTION_DELETE_THRESHOLD=6
REACTION_TIMEOUT_MINUTES=1
TIMEOUT_EXEMPT_USER_IDS=1361193257157263451

# Twitter/X link fix
TWITTER_FIX_DATA_FILE=data/twitter_fix_data.json

# Optional legacy commands (disabled in the original bot.py)
ENABLE_JANKEN=false
JANKEN_CHANNEL_ID=1361231995262337157
JANKEN_LEADERBOARD_FILE=data/janken_leaderboard.json

ENABLE_OSHIRASE=false
